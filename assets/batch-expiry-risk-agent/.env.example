# ─────────────────────────────────────────────
# Batch Expiry Risk Agent — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────

# ── SAP AI Core (LLM) ────────────────────────
# Found in your AI Core service key (JSON) under:
#   "credentials" → "clientid", "clientsecret", "url", "serviceurls.AI_API_URL"
AICORE_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=<your-client-id>
AICORE_CLIENT_SECRET=<your-client-secret>
AICORE_BASE_URL=https://api.ai.<region>.ml.hana.ondemand.com
# Resource group that hosts your deployed LLM (default: "default")
AICORE_RESOURCE_GROUP=default

# ── SAP Agent Gateway (MCP tool routing) ─────
# Paste the entire service key JSON as a single-line string, or leave blank
# to run in mock/testing mode (IBD_TESTING=1 below).
# AGW_CREDENTIALS_JSON={"clientid":"...","clientsecret":"...","url":"..."}

# ── Run mode ──────────────────────────────────
# Set to 1 to use mcp-mock.json instead of live SAP connections (local dev/CI).
# Remove or set to 0 for production (requires AICORE_* and AGW above).
IBD_TESTING=1

# ── Agent server ──────────────────────────────
# Port the A2A server listens on (default: 5000)
# PORT=5000
# Public URL announced in the agent card (leave blank for local dev)
# AGENT_PUBLIC_URL=https://your-agent.cfapps.<region>.hana.ondemand.com

# ── OpenTelemetry (optional) ──────────────────
# Set to your OTEL collector endpoint to enable trace export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
